{
  "name": "postgres-ssl",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "bun@1.3.14",
  "description": "This repository contains the logic to build SSL-enabled Postgres images.",
  "author": "Nicolas Contiero <https://github.com/ncontiero>",
  "license": "MIT",
  "scripts": {
    "generate": "dkcutter .",
    "generate-matrix": "bun run scripts/generate-matrix.ts",
    "update-versions": "bun run scripts/update-versions.ts",
    "test": "bun test",
    "lint": "eslint .",
    "lint:fix": "bun run lint --fix",
    "typecheck": "tsc --noEmit",
    "check": "bun run lint && bun run typecheck && bun run test"
  },
  "devDependencies": {
    "@ncontiero/eslint-config": "8.2.2",
    "@types/bun": "1.3.14",
    "dkcutter": "6.0.2",
    "eslint": "10.4.1",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": "^22.3.0 || >=24.0.0"
  }
}
